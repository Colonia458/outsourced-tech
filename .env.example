# Outsourced Technologies - Environment Variables Template
# Copy this to .env and fill in your values

# Application Environment (use 'production' for live sites)
APP_ENV=development

# Database Configuration
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=outsourced_tech
DB_USER=root
DB_PASS=

# Base URL
BASE_URL=http://localhost/outsourced/public/

# CORS — set to your actual frontend domain in production (e.g. https://yourdomain.com)
ALLOWED_ORIGIN=http://localhost

# M-Pesa Configuration (get these from https://developer.safaricom.co.ke)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost/outsourced/api/mpesa/callback.php

# Backup endpoint secret key — change this to a long random string
BACKUP_SECRET_KEY=change-me-to-a-long-random-string

# Email Configuration (SMTP)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@outsourcedtechnologies.co.ke
MAIL_FROM_NAME="Outsourced Technologies"
